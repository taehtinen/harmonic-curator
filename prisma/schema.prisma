// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  USER
  ADMIN
}

model User {
  id           BigInt     @id @default(autoincrement())
  username     String     @unique
  passwordHash String
  status       UserStatus @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  playlists           Playlist[]
  spotifyAccounts     UserSpotifyAccount[]

  @@map("user")
}

/**
 * Linked Spotify OAuth identities for an app user (multiple accounts per user).
 * Tokens are AES-256-GCM ciphertext (see lib/token-crypto.ts); never store plaintext.
 */
model UserSpotifyAccount {
  id                   BigInt    @id @default(autoincrement())
  userId               BigInt
  spotifyUserId        String
  refreshTokenEnc      String
  accessTokenEnc       String?
  accessTokenExpiresAt DateTime?
  scope                String
  displayName          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, spotifyUserId])
  @@index([userId])
  @@map("user_spotify_account")
}

model Artist {
  id           BigInt   @id @default(autoincrement())
  spotifyId    String   @unique
  name         String
  genres       String[]
  popularity   Int
  followers    Int
  isIgnored    Boolean  @default(false)
  topTracksRefreshedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tracks       Track[]
  trackArtists TrackArtist[]
  albums       Album[]

  @@index([topTracksRefreshedAt])
  @@map("artist")
}

model Album {
  id          BigInt   @id @default(autoincrement())
  spotifyId   String   @unique
  artistId    BigInt
  name        String
  releaseDate String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tracks      Track[]

  artist      Artist   @relation(fields: [artistId], references: [id])

  @@index([artistId])

  @@map("album")
}

model Track {
  id             BigInt   @id @default(autoincrement())
  spotifyId      String   @unique
  artistId       BigInt
  albumId        BigInt
  name           String
  popularity     Int
  trackNumber    Int      
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  album          Album         @relation(fields: [albumId], references: [id])
  artist         Artist        @relation(fields: [artistId], references: [id])
  trackArtists   TrackArtist[]
  playlistTracks PlaylistTrack[]

  @@index([albumId])
  @@index([artistId])
  @@map("track")
}

model TrackArtist {
  trackId  BigInt
  artistId BigInt

  track  Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([trackId, artistId])
  @@index([artistId])
  @@map("track_artist")
}

model Playlist {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt
  /** Set when the row is tied to a Spotify playlist; null for app-only playlists. */
  spotifyId      String?  @unique
  name           String
  description    String   @default("")
  genres         String[]
  maxFollowers   Int?
  size           Int
  /** Last time local `playlist_track` rows were written (reorder/add/remove, including import seed). */
  lastTrackEditAt DateTime?
  /**
   * Last time this app pushed playlist tracks to Spotify, or the latest Spotify `added_at` on import seed
   * (most recent track addition among rows we keep).
   */
  lastSpotifyPublishAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  playlistTracks PlaylistTrack[]

  @@index([name])
  @@index([userId])
  @@map("playlist")
}

model PlaylistTrack {
  id         BigInt   @id @default(autoincrement())
  playlistId BigInt
  trackId    BigInt
  position   Int
  createdAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, position])
  @@index([playlistId])
  @@index([trackId])
  @@map("playlist_track")
}
